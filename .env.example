RABBITMQ_VHOST=iot

RABBITMQ_ADMIN_USER=rmq_admin
RABBITMQ_ADMIN_PASSWORD=replace-with-a-strong-rabbitmq-admin-password

RABBITMQ_PUBLISHER_USER=iot_publisher
RABBITMQ_PUBLISHER_PASSWORD=replace-with-a-strong-rabbitmq-publisher-password

RABBITMQ_CONSUMER_USER=iot_consumer
RABBITMQ_CONSUMER_PASSWORD=replace-with-a-strong-rabbitmq-consumer-password

NODE_RED_CREDENTIAL_SECRET=replace-with-a-long-random-node-red-credential-secret

MONGO_INITDB_ROOT_USERNAME=mongo_root
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-strong-mongodb-root-password
MONGO_APP_DATABASE=iot_telemetry
MONGO_APP_USERNAME=iot_consumer
MONGO_APP_PASSWORD=replace-with-a-strong-mongodb-app-password

CONSUMER_MONGO_CONNECTION_STRING=mongodb://iot_consumer:replace-with-a-url-encoded-mongodb-app-password@mongodb:27017/iot_telemetry
CONSUMER_RABBITMQ_PREFETCH=8
